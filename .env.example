# Cloudflare Tunnel Token
# Get this from Cloudflare Zero Trust → Networks → Tunnels → Create Tunnel
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here

# MySQL root password (optional, default: wordmemory)
MYSQL_ROOT_PASSWORD=wordmemory

# JWT signing key — CHANGE THIS in production!
# Generate: openssl rand -base64 64
JWT_KEY=change-me-in-production

# Frontend port on host (optional, default: 80)
FRONTEND_PORT=80
