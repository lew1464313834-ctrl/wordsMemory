{
    "name": "wordmemory/backend",
    "description": "WordMemory ThinkPHP 8 Backend",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "topthink/framework": "^8.0",
        "firebase/php-jwt": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "app\\": "app"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "composer/advisory-plugin": true
        }
    }
}
